{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/outbound-payload-lineage/lineage-report.schema.json",
  "title": "Outbound Payload Lineage Report",
  "type": "object",
  "required": ["schemaVersion", "object", "summary", "objectShape", "fields"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of this lineage JSON contract. Use 1.0.0 for this skill package."
    },
    "object": {
      "type": "object",
      "required": ["name", "outboundSurface"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "package": { "type": "string" },
        "className": { "type": "string" },
        "outboundSurface": {
          "type": "object",
          "required": ["class", "method"],
          "additionalProperties": true,
          "properties": {
            "class": { "type": "string" },
            "method": { "type": "string" },
            "file": { "type": "string" },
            "line": { "type": ["integer", "string", "null"] },
            "transport": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["fieldsFound", "highConfidence", "mediumConfidence", "lowConfidence"],
      "additionalProperties": true,
      "properties": {
        "fieldsFound": { "type": "integer", "minimum": 0 },
        "highConfidence": { "type": "integer", "minimum": 0 },
        "mediumConfidence": { "type": "integer", "minimum": 0 },
        "lowConfidence": { "type": "integer", "minimum": 0 },
        "primaryOrigins": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "objectShape": { "$ref": "#/$defs/shapeNode" },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fieldReport" }
    },
    "boundaries": {
      "type": "array",
      "items": { "$ref": "#/$defs/boundary" }
    },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    }
  },
  "$defs": {
    "shapeNode": {
      "type": "object",
      "required": ["name", "path", "kind", "type"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["object", "array", "field"]
        },
        "type": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "mappingType": { "type": "string" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/shapeNode" }
        }
      }
    },
    "fieldReport": {
      "type": "object",
      "required": ["path", "confidence", "mappingType", "lineage"],
      "additionalProperties": true,
      "properties": {
        "path": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "mappingType": { "type": "string" },
        "description": { "type": "string" },
        "lineage": {
          "type": "object",
          "required": ["nodes", "edges"],
          "additionalProperties": true,
          "properties": {
            "nodes": {
              "type": "array",
              "items": { "$ref": "#/$defs/lineageNode" }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "array",
                "minItems": 3,
                "maxItems": 4,
                "items": { "type": "string" }
              },
              "description": "Each edge is [sourceNodeId, targetNodeId, label, optionalEdgeType]. Use FIELD as the source for the selected output field node."
            }
          }
        }
      }
    },
    "lineageNode": {
      "type": "object",
      "required": ["id", "kind", "title"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": [
            "object",
            "group",
            "array",
            "field",
            "assignment",
            "transform",
            "source",
            "method",
            "repository",
            "event",
            "external",
            "config",
            "constant",
            "runtime",
            "unknown"
          ]
        },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "meta": { "type": "string" },
        "file": { "type": "string" },
        "class": { "type": "string" },
        "method": { "type": "string" },
        "line": { "type": ["integer", "string", "null"] },
        "snippet": { "type": "string" },
        "tier": { "type": "integer" },
        "row": { "type": "integer" }
      }
    },
    "boundary": {
      "type": "object",
      "required": ["type", "title"],
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "gap": {
      "type": "object",
      "required": ["title", "severity"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["high", "medium", "low"] },
        "description": { "type": "string" },
        "fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  }
}
